# Copy this file to .env.development / .env.staging / .env.production and
# fill in the values for each environment. APP_ENV (set on the shell or by
# the eas.json build profile) selects which one app.config.ts loads.

# Base URL of the backend API, WITHOUT the /api/v1 suffix (client.ts appends it).
API_BASE_URL=https://api.dev.studyverse.ai

# Suffix appended to the human-readable app name shown on the device home
# screen, e.g. "StudyVerse (Dev)", "StudyVerse (Staging)", "StudyVerse".
APP_NAME_SUFFIX=(Dev)

# Suffix appended to the iOS bundle identifier / Android package so that
# development, staging and production builds can be installed side by side
# on the same device, e.g. "com.studyverse.app.dev".
BUNDLE_ID_SUFFIX=.dev

# OAuth client IDs used by expo-auth-session's Google provider. Create these
# in the Google Cloud Console (OAuth consent screen + credentials) for each
# platform/environment. Leave blank in this example file.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
