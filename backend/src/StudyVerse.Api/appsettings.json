{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Jwt": {
    "Issuer": "StudyVerseAi",
    "Audience": "StudyVerseAi.Clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "AppUrls": {
    "EmailVerificationUrlTemplate": "https://app.studyverse.ai/verify-email?userId={userId}&token={token}",
    "PasswordResetUrlTemplate": "https://app.studyverse.ai/reset-password?email={email}&token={token}"
  },
  "Google": {
    "ClientId": ""
  },
  "Apple": {
    "ClientId": ""
  }
}
