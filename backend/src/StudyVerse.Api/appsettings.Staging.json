{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/studyverse-staging-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "ConnectionStrings": {
    // Host/port are environment-specific but not secret; the password segment is a placeholder —
    // override the whole value via the ConnectionStrings__Postgres environment variable at deploy time.
    "Postgres": "Host=staging-postgres;Port=5432;Database=studyverse;Username=studyverse;Password=REPLACE_VIA_ENV_VAR"
  },
  "Redis": {
    "ConnectionString": "staging-redis:6379"
  },
  "AppUrls": {
    "EmailVerificationUrlTemplate": "https://staging.studyverse.ai/verify-email?userId={userId}&token={token}",
    "PasswordResetUrlTemplate": "https://staging.studyverse.ai/reset-password?email={email}&token={token}"
  },
  "OpenAI": {
    // No placeholder key here, ever — must be supplied via the OpenAI__ApiKey environment
    // variable or the deployment's secret manager.
    "ApiKey": ""
  },
  "GNews": {
    // No placeholder key here, ever — must be supplied via the GNews__ApiKey environment
    // variable or the deployment's secret manager.
    "ApiKey": ""
  }
}
