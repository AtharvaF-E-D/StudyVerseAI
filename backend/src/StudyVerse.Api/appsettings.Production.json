{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "StudyVerse": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/studyverse/studyverse-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "ConnectionStrings": {
    // Intentionally blank — must be supplied via the ConnectionStrings__Postgres environment
    // variable. No production secrets are ever checked into this file.
    "Postgres": ""
  },
  "Redis": {
    // Intentionally blank — must be supplied via the Redis__ConnectionString environment variable.
    "ConnectionString": ""
  },
  "AppUrls": {
    "EmailVerificationUrlTemplate": "https://app.studyverse.ai/verify-email?userId={userId}&token={token}",
    "PasswordResetUrlTemplate": "https://app.studyverse.ai/reset-password?email={email}&token={token}"
  },
  "OpenAI": {
    // No placeholder key here, ever — must be supplied via the OpenAI__ApiKey environment
    // variable or the deployment's secret manager.
    "ApiKey": ""
  },
  "GNews": {
    // No placeholder key here, ever — must be supplied via the GNews__ApiKey environment
    // variable or the deployment's secret manager.
    "ApiKey": ""
  },
  "Judge0": {
    // No placeholder key here, ever — must be supplied via the Judge0__RapidApiKey environment
    // variable or the deployment's secret manager.
    "RapidApiKey": ""
  }
}
